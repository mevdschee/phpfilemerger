{
    "name": "phpfilemerger/phpfilemerger",
    "description": "Intelligently merge PHP files and dependencies into a single file",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "nikic/php-parser": "^5.0",
        "psr/event-dispatcher": "^1.0",
        "symfony/console": "^6.0 || ^7.0",
        "symfony/deprecation-contracts": "^3.6",
        "symfony/event-dispatcher-contracts": "^3.6",
        "symfony/finder": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "PhpFileMerger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpFileMerger\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/phpfilemerger"],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
